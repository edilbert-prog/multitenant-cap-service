{
  "name": "testing-saas-demo-app",
  "version": "1.0.0",
  "description": "CAP SaaS multitenant application with PostgreSQL",
  "private": true,
  "dependencies": {
    "@cap-js/postgres": "^2.1.2",
    "@cap-js/sqlite": "^2.1.3",
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^9",
    "@sap/cds-mtxs": "^3.7.1",
    "@sap/xsenv": "^6.0.0",
    "@sap/xssec": "^4.12.2",
    "express": "^4",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.6.1",
    "cpy-cli": "^7.0.0"
  },
  "scripts": {
    "start": "cds deploy && cds run",
    "watch": "cds watch",
    "deploy": "cds deploy",
    "build": "npm run build:ui && npm run copy:ui",
    "build:ui": "cd cognito_ai_web && npm run build",
    "copy:ui": "cpy cognito_ai_web/dist/** approuter/build",
    "cf:deploy": "cf push",
    "cf:deploy:approuter": "npm run build && cd approuter && cf push",
    "sync-env": "node scripts/syncDefaultEnv.js"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "postgres"
      },
      "auth": {
        "kind": "xsuaa"
      },
      "ExternalAPI": {
        "kind": "rest",
        "credentials": {
          "destination": "ExternalAPI"
        }
      }
    },
    "security": {
    "csrf": false
    },
    "multitenancy": {
      "enabled": true
    },
    "features": {
      "mtx": true
    },
    "deploy": {
      "auto": true
    }
  }
}
