{
  "name": "testing-saas-demo-app",
  "version": "1.0.0",
  "description": "CAP SaaS multitenant application with PostgreSQL",
  "private": true,

  "dependencies": {
    "@sap/cds": "^9",
    "@sap/cds-mtxs": "^3.7.1",
    "@cap-js/postgres": "^2.1.2",
    "@cap-js/sqlite": "^2.1.3",
    "@sap/xsenv": "^6.0.0",
    "@sap/xssec": "^4.12.2",
    "express": "^4"
  },

  "devDependencies": {
    "@sap/cds-dk": "^9.6.1",
    "cpy-cli": "^7.0.0"
  },

  "scripts": {
    "start": "cds deploy && cds run",

    "watch": "cds watch",

    "deploy": "cds deploy",

    "build": "npm run build:ui && npm run copy:ui",

    "build:ui": "cd app && npm install && npm run build",

    "copy:ui": "cpy app/build/** approuter/build --parents",

    "cf:deploy": "cf push",

    "cf:deploy:approuter": "npm run build && cd approuter && cf push",

    "sync-env": "node scripts/syncDefaultEnv.js"
  },

  "cds": {
    "requires": {
      "db": {
        "kind": "postgres"
      },
      "auth": {
        "kind": "xsuaa"
      }
    },

    "multitenancy": {
      "enabled": true
    },

    "features": {
      "mtx": true
    },
    "deploy": {
    "auto": true
    }
  }
}